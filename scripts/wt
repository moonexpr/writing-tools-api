#!/bin/zsh
# wt — Shortcuts-friendly wrapper for wtsurface.
# Reads text on stdin, runs an ai mode, and retries once if the on-device
# model throws the transient first-run "ModelManagerError 1013".
#
# Usage (in a Shortcuts "Run Shell Script", pass input to stdin):
#   /Users/jc/GitRepos/writing-tools-api/scripts/wt proofread
#   /Users/jc/GitRepos/writing-tools-api/scripts/wt summarize
#   /Users/jc/GitRepos/writing-tools-api/scripts/wt rewrite

BIN="${0:A:h:h}/wtsurface"          # repo-root/wtsurface, resolved from this script
ARGS=("$@")                          # e.g. "proofread" or "--pcc summarize"
[[ ${#ARGS[@]} -eq 0 ]] && ARGS=(proofread)
TEXT="$(cat)"

run() { print -r -- "$TEXT" | "$BIN" ai "${ARGS[@]}" 2>/dev/null; }

out="$(run)"; code=$?
# Retry once only for the transient first-run warm-up (exit 1); not for context
# overflow (exit 2), which a retry can't fix.
if [[ $code -eq 1 || "$out" == ERROR:* ]]; then
    sleep 1
    out="$(run)"
fi
print -r -- "$out"
